assign seg_ones[6] = \seg_ones[6]~output_o ;

assign seg_tens[0] = \seg_tens[0]~output_o ;

assign seg_tens[1] = \seg_tens[1]~output_o ;

assign seg_tens[2] = \seg_tens[2]~output_o ;

assign seg_tens[3] = \seg_tens[3]~output_o ;

assign seg_tens[4] = \seg_tens[4]~output_o ;

assign seg_tens[5] = \seg_tens[5]~output_o ;

assign seg_tens[6] = \seg_tens[6]~output_o ;

assign digit_select[0] = \digit_select[0]~output_o ;

assign digit_select[1] = \digit_select[1]~output_o ;

assign pedestrian_go = \pedestrian_go~output_o ;

assign traffic_state[0] = \traffic_state[0]~output_o ;

